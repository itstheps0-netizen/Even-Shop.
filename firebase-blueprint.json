{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and balance.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "balance": { "type": "number", "description": "Virtual balance for purchases" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Diamond packs or panels for sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["topup", "panels", "bots"] },
        "imageUrl": { "type": "string" },
        "stock": { "type": "number" },
        "active": { "type": "boolean" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "Purchase transaction records.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "gameId": { "type": "string", "description": "FF Player ID" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "amount", "status"]
    },
    "Review": {
      "title": "User Review",
      "description": "Feedback and ratings from users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "isFake": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "rating", "comment"]
    },
    "Support": {
      "title": "Support Message",
      "description": "Chat messages between user and admin.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Available products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Order records"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "User reviews and ratings"
    },
    "/support/{msgId}": {
      "schema": "Support",
      "description": "Support chat history"
    },
    "/gallery/{imgId}": {
      "schema": { "type": "object", "properties": { "url": { "type": "string" }, "createdAt": { "type": "string" } } },
      "description": "Uploaded asset gallery"
    }
  }
}
